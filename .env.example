# Copy this file to `.env` and fill in the values you want to override.
#
# Credentials themselves are NOT read from this file — they come from the
# standard boto3 chain (the AWS CLI, env vars exported in your shell, an
# IAM role, etc.). This file only configures the region + model id, and
# optionally selects a named profile.

# AWS region the Bedrock client should target.
AWS_REGION=us-east-1

# Bedrock model id used by the LLM demo and any ReactAgent that doesn't
# pass a model explicitly. Override per agent role if you want a cheaper
# model for one role and a stronger one for another.
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# Optional named profile from `aws configure list-profiles`. Leave unset
# to use the default credential chain.
# AWS_PROFILE=default

# ── OpenRouter — unified API for 100+ LLM providers ─────────────────────

# Required to use ahp.llm.openrouter. Sign up at https://openrouter.ai.
# OPENROUTER_API_KEY=sk-or-v1-...

# Default model the openrouter_chat_model() helper uses when no model
# is passed explicitly. OpenRouter model ids are vendor-prefixed
# (e.g. "anthropic/claude-3.5-sonnet", "meta-llama/llama-3-70b-instruct").
# OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Override only if you're proxying through your own gateway.
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
